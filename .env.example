# PostgreSQL (用于问数业务数据)
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/nl2sql

# MySQL (用于平台数据：历史记录、用户偏好等)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=nl2sql_platform

# LLM 配置
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_MODEL=gpt-4o-mini
USE_MOCK_LLM=true

# SQL 执行配置
SQL_MAX_ROWS=200
SQL_MAX_ATTEMPTS=2

# 通义千问 Embedding 配置（用于混合检索）
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_EMBEDDING_MODEL=text-embedding-v3
QWEN_EMBEDDING_DIM=1024
